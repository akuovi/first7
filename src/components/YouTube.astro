---
const { id } = Astro.props;

const thumbnail = `https://img.youtube.com/vi/${id}/hqdefault.jpg`;
const videoUrl = `https://www.youtube.com/watch?v=${id}`;
---

<a 
  href={videoUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="block relative w-full aspect-video my-6 group"
>

  <!-- Thumbnail -->
  <img
    src={thumbnail}
    alt="YouTube thumbnail"
    class="w-full h-full object-cover rounded-xl"
    loading="lazy"
  />

  <!-- Overlay -->
  <div class="absolute inset-0 flex items-center justify-center">

    <!-- SVG Play Button -->
    <div class="transition group-hover:scale-110">
      <svg width="68" height="48" viewBox="0 0 68 48">
        <path d="M66.52 7.02a8 8 0 0 0-5.63-5.66C56.7 0 34 0 34 0S11.3 0 7.11 1.36a8 8 0 0 0-5.63 5.66A83.4 83.4 0 0 0 0 24a83.4 83.4 0 0 0 1.48 16.98 8 8 0 0 0 5.63 5.66C11.3 48 34 48 34 48s22.7 0 26.89-1.36a8 8 0 0 0 5.63-5.66A83.4 83.4 0 0 0 68 24a83.4 83.4 0 0 0-1.48-16.98z" fill="#FF0000"/>
        <path d="M45 24 27 14v20" fill="#FFFFFF"/>
      </svg>
    </div>

  </div>

  <!-- Label -->
  <div class="absolute bottom-2 right-2 text-xs bg-black/70 px-2 py-1 rounded text-white">
    Watch on YouTube
  </div>

</a>