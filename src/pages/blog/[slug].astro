---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ReadingLayout from '../../layouts/ReadingLayout.astro';

type BlogEntry = CollectionEntry<'blog'>;

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props as { post: BlogEntry };
const { Content } = await render(post);
---

<ReadingLayout title={post.data.title}>
  <div class="mb-6 text-sm text-[var(--color-muted)]">
    <p>{post.data.date.toLocaleDateString()}</p>
  </div>

  <div class="space-y-6 text-lg leading-relaxed">
    <Content />
  </div>

  <div class="my-10 border-t border-[var(--color-border)]"></div>

  <div class="flex justify-between text-sm text-[var(--color-muted)]">
    <a href="/blog">{'<-'} Back to Blog</a>
    <span>{post.data.tags.join(', ')}</span>
  </div>
</ReadingLayout>
