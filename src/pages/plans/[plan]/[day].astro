---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import VerseLink from '../../../components/VerseLink.astro';
import ReadingLayout from '../../../layouts/ReadingLayout.astro';

type StartEntry = CollectionEntry<'start'>;

export async function getStaticPaths() {
  const entries = await getCollection('start');

  return entries.map((entry) => ({
    params: {
      plan: entry.data.plan,
      day: `day-${entry.data.day}`
    },
    props: { entry }
  }));
}

const { entry } = Astro.props as { entry: StartEntry };

const allEntries = await getCollection('start');
const planEntries = allEntries
  .filter((candidate) => candidate.data.plan === entry.data.plan)
  .sort((a, b) => a.data.day - b.data.day);

const currentIndex = planEntries.findIndex((candidate) => candidate.id === entry.id);
const previousEntry = currentIndex > 0 ? planEntries[currentIndex - 1] : undefined;
const nextEntry = currentIndex >= 0 ? planEntries[currentIndex + 1] : undefined;

const { Content } = await render(entry);

const plan = entry.data.plan;
const day = entry.data.day;
const totalDays = planEntries.length;
---

<ReadingLayout title={entry.data.title}>

  <div class="mx-auto max-w-2xl px-5 py-10 space-y-12">

    <!-- 🧭 PROGRESS -->
    <div class="space-y-4">

      <div class="flex items-center justify-between text-sm text-[var(--color-muted)]">
        <span>Day {day} of {totalDays}</span>
        <span>{Math.round((day / totalDays) * 100)}%</span>
      </div>

      <div class="flex gap-2">
        {Array.from({ length: totalDays }).map((_, i) => (
          <div
            class={`h-2 flex-1 rounded-full transition ${
              i < day
                ? 'bg-[var(--color-primary)]'
                : 'bg-[var(--color-border)]'
            }`}
          />
        ))}
      </div>

    </div>

    <!-- 📖 TITLE -->
    <div class="space-y-3">
      <h1 class="text-3xl md:text-4xl font-semibold leading-tight tracking-tight">
        {entry.data.title}
      </h1>

      <p class="text-[var(--color-muted)] leading-relaxed">
        {entry.data.description}
      </p>
    </div>

    <!-- ✨ FOCUS VERSE -->
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 p-6 space-y-3">

      <p class="text-xs uppercase tracking-wide text-[var(--color-muted)]">
        Today’s Focus
      </p>

      <p class="text-lg font-medium leading-relaxed">
        <VerseLink verse={entry.data.verse} />
      </p>

    </div>

    <!-- 📖 READ -->
    <div class="space-y-6">
      <p class="text-xs uppercase tracking-wide text-[var(--color-muted)]">
        Read
      </p>

      <article class="space-y-6 text-lg leading-relaxed">
        <Content />
      </article>
    </div>

    <!-- 🔁 STREAK -->
    <div class="rounded-xl border bg-[var(--color-primary)]/5 p-5 flex items-center justify-between">
      <div>
        <p class="text-sm text-[var(--color-muted)]">Your streak</p>
        <p id="streak-count" class="text-2xl font-semibold">0 days</p>
      </div>

      <div class="text-3xl">🔥</div>
    </div>

    <!-- 🎯 ACTION -->
    <div class="text-center space-y-4">

      <button
        id="complete-btn"
        class="w-full rounded-xl bg-[var(--color-primary)] px-6 py-4 text-white font-medium text-lg shadow-sm hover:shadow-md hover:scale-[1.01] transition"
        type="button"
      >
        Complete Day {day} →
      </button>

      <a
        id="next-btn"
        class="hidden text-sm text-[var(--color-muted)] hover:text-[var(--color-primary)] transition"
      >
        Skip →
      </a>

    </div>

    <!-- 🎉 COMPLETION -->
    <div
      id="celebration-box"
      class="hidden rounded-2xl border bg-[var(--color-primary)]/10 p-6 text-center space-y-2"
    >
      <p class="text-sm text-[var(--color-muted)]">Completed</p>
      <h2 class="text-2xl font-semibold">You finished this plan 🎉</h2>
      <p class="text-[var(--color-muted)]">
        Keep going — your journey is just beginning.
      </p>
    </div>

    <!-- 🔙 NAV -->
    <div class="flex justify-between text-sm text-[var(--color-muted)]">

      {previousEntry ? (
        <a href={`/plans/${plan}/day-${previousEntry.data.day}`} class="hover:text-[var(--color-primary)]">
          ← Day {previousEntry.data.day}
        </a>
      ) : <span />}

      {nextEntry ? (
        <a href={`/plans/${plan}/day-${nextEntry.data.day}`} class="hover:text-[var(--color-primary)]">
          Day {nextEntry.data.day} →
        </a>
      ) : <span />}

    </div>

  </div>

  <!-- 🧠 SCRIPT -->
  <script is:inline define:vars={{ plan, day, totalDays }}>
    const getSavedDays = (storageKey) => {
      try {
        const rawValue = localStorage.getItem(storageKey);
        const parsed = rawValue ? JSON.parse(rawValue) : [];
        return Array.isArray(parsed) ? parsed.filter((value) => Number.isInteger(value)) : [];
      } catch {
        return [];
      }
    };

    const storageKey = `first7-${plan}`;
    let savedDays = getSavedDays(storageKey);

    const completeButton = document.getElementById('complete-btn');
    const nextButton = document.getElementById('next-btn');
    const celebrationBox = document.getElementById('celebration-box');
    const streakCount = document.getElementById('streak-count');

    if (streakCount) {
      streakCount.textContent = `${savedDays.length} day${savedDays.length === 1 ? '' : 's'}`;
    }

    const showCompletionState = () => {
      if (completeButton) {
        completeButton.textContent = 'Completed ✓';
        completeButton.disabled = true;
      }

      if (day < totalDays && nextButton instanceof HTMLAnchorElement) {
        nextButton.href = `/plans/${plan}/day-${day + 1}`;
        nextButton.classList.remove('hidden');
      } else {
        celebrationBox?.classList.remove('hidden');
      }
    };

    if (savedDays.includes(day)) {
      showCompletionState();
    }

    completeButton?.addEventListener('click', () => {
      if (!savedDays.includes(day)) {
        savedDays = [...savedDays, day].sort((a, b) => a - b);
        localStorage.setItem(storageKey, JSON.stringify(savedDays));
      }

      if (streakCount) {
        streakCount.textContent = `${savedDays.length} day${savedDays.length === 1 ? '' : 's'}`;
      }

      showCompletionState();

      if (day < totalDays) {
        setTimeout(() => {
          window.location.href = `/plans/${plan}/day-${day + 1}`;
        }, 700);
      }
    });
  </script>

</ReadingLayout>