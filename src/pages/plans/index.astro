---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = await getCollection('start');
const plans: Record<string, CollectionEntry<'start'>[]> = Object.create(null);

for (const entry of entries) {
  const plan = entry.data.plan;
  plans[plan] ??= [];
  plans[plan].push(entry);
}

const knownPlans = Object.keys(plans).sort();
---

<BaseLayout>

  <section class="max-w-5xl mx-auto py-16 px-4 space-y-12">

    <!-- HEADER -->
    <div class="text-center max-w-2xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-semibold">
        Start Your Journey
      </h1>
      <p class="mt-3 text-[var(--color-muted)]">
        Choose a 7-day plan to grow your faith, step by step.
      </p>
    </div>

    <!-- HOW TO USE CTA -->
    <div class="flex justify-center">
      <a
        href="/guides/how-to-use"
        class="px-5 py-2.5 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-primary)] transition"
      >
        How to use this →
      </a>
    </div>

    <!-- PLANS GRID -->
    <div class="grid gap-6 md:grid-cols-2">

      {Object.entries(plans)
        .sort(([left], [right]) => left.localeCompare(right))
        .map(([plan, days]) => (

          <a
            href={`/plans/${plan}`}
            class="group p-6 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] hover:shadow-md transition"
          >
            <div class="flex items-center justify-between">

              <h2 class="text-xl font-semibold capitalize">
                {plan.replace(/-/g, ' ')}
              </h2>

              <span class="text-sm text-[var(--color-muted)]">
                {days.length} days
              </span>

            </div>

            <p class="mt-3 text-sm text-[var(--color-muted)]">
              A guided journey to help you grow daily.
            </p>

            <div class="mt-5 text-[var(--color-primary)] text-sm font-medium flex items-center gap-1">
              Start →
            </div>

          </a>

        ))}

    </div>

    <!-- CONTINUE BOX -->
    <div id="reminder-box" class="hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 p-6 text-center">

      <p class="text-sm text-[var(--color-muted)]">
        Continue your journey
      </p>

      <p class="mt-2 text-lg font-medium">
        Don’t break your streak
      </p>

      <a
        id="continue-btn"
        class="mt-4 inline-block px-5 py-2.5 rounded-lg text-white font-medium"
        style="background-color: var(--color-primary);"
      >
        Continue →
      </a>

    </div>

  </section>

  <!-- KEEP YOUR SCRIPT (no change needed) -->

  <script is:inline define:vars={{ knownPlans }}>
    const getSavedDays = (storageKey) => {
      try {
        const rawValue = localStorage.getItem(storageKey);
        const parsed = rawValue ? JSON.parse(rawValue) : [];
        return Array.isArray(parsed) ? parsed.filter((value) => Number.isInteger(value)) : [];
      } catch {
        return [];
      }
    };

    let latestPlan = null;
    let latestDay = 0;

    knownPlans.forEach((planName) => {
      const completedDays = getSavedDays(`first7-${planName}`);

      if (completedDays.length === 0) {
        return;
      }

      const maxDay = Math.max(...completedDays);

      if (maxDay > latestDay) {
        latestDay = maxDay;
        latestPlan = planName;
      }
    });

    const reminderBox = document.getElementById('reminder-box');
    const continueButton = document.getElementById('continue-btn');

    if (
      latestPlan &&
      reminderBox instanceof HTMLElement &&
      continueButton instanceof HTMLAnchorElement
    ) {
      reminderBox.classList.remove('hidden');
      continueButton.href = `/plans/${latestPlan}/day-${latestDay + 1}`;
    }
  </script>
</BaseLayout>
