---
import { getCollection, type CollectionEntry } from 'astro:content';
import ReadingLayout from '../../layouts/ReadingLayout.astro';

type DownloadEntry = CollectionEntry<'downloads'>;

export async function getStaticPaths() {
  const items = await getCollection('downloads');

  return items.map((item) => ({
    params: { slug: item.id },
    props: { item }
  }));
}

const { item } = Astro.props as { item: DownloadEntry };
---

<ReadingLayout title={item.data.title}>
  <p class="mb-6 text-lg text-[var(--color-muted)]">{item.data.description}</p>

  <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 p-6">
    <p class="mb-2 text-sm text-[var(--color-muted)]">File ready to download</p>

    <a
      href={item.data.file}
      target="_blank"
      rel="noreferrer"
      class="inline-block rounded-xl bg-[var(--color-primary)] px-6 py-3 text-lg font-medium text-white"
    >
      Download Now ->
    </a>
  </div>

  <div class="my-10 border-t border-[var(--color-border)]"></div>

  <div class="text-sm text-[var(--color-muted)]">
    <a href="/downloads" class="hover:underline">{'<-'} Back to Downloads</a>
  </div>
</ReadingLayout>
