---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Support This Project">

  <div class="max-w-2xl mx-auto text-center space-y-6 py-16">

    <h1 class="text-3xl font-semibold">
      Support This Project
    </h1>

    <p class="text-[var(--color-muted)]">
      If First7 has helped you grow in your faith, you can support its continued development.
    </p>

    <p class="text-[var(--color-muted)]">
      Your support helps keep this site simple, fast, and accessible to everyone.
    </p>

    <!-- BUTTONS (add later) -->
    <div class="flex justify-center gap-4 pt-4">

      <a
        href="#"
        class="px-6 py-3 rounded-lg bg-[var(--color-primary)] text-white font-medium"
      >
        Donate
      </a>

    </div>

    <p class="text-xs text-[var(--color-muted)] pt-6">
      Thank you for supporting this work.
    </p>

  </div>

</BaseLayout>