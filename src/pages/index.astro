---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const devotionals = (await getCollection("devotionals")).slice(0, 3);
const plans = await getCollection("start");

const uniquePlans = [...new Set(plans.map(p => p.data.plan))];
---

<BaseLayout title="First7 - Build Your Daily Faith">

  <div class="mx-auto max-w-5xl px-5 py-16 space-y-20">

    <!-- 🔁 RESUME -->
    <div
      id="resume-box"
      class="hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-primary)]/10 p-6 shadow-sm"
    >
      <p class="text-sm text-[var(--color-muted)]">Continue your journey</p>

      <a
        id="resume-link"
        class="mt-2 inline-block text-lg font-semibold text-[var(--color-primary)]"
      >
        Resume →
      </a>
    </div>

    <!-- HERO -->
    <section class="text-center space-y-8">

      <h1 class="text-4xl md:text-6xl font-semibold leading-tight tracking-tight">
        Build a Daily Rhythm  
        <span class="block text-[var(--color-primary)]">of Faith</span>
      </h1>

      <p class="text-[var(--color-muted)] text-lg max-w-xl mx-auto leading-relaxed">
        Read Scripture, reflect deeply, and grow consistently —  
        one day at a time.
      </p>

      <div class="flex justify-center gap-4 flex-wrap mt-6">

        <a
          href="/guides/how-to-use"
          class="px-6 py-3 rounded-xl bg-[var(--color-primary)] text-white font-medium shadow-sm hover:shadow-md hover:scale-[1.02] transition"
        >
          Start Here
        </a>

        <a
          href="/plans"
          class="px-6 py-3 rounded-xl border border-[var(--color-border)] hover:bg-[var(--color-primary)]/10 transition"
        >
          Browse Plans
        </a>

      </div>

    </section>

    <!-- 🧠 SYSTEM -->
    <section class="space-y-8">

      <h2 class="text-2xl font-semibold text-center">
        A simple system for daily growth
      </h2>

      <div class="grid md:grid-cols-3 gap-6 text-sm">

        <div class="p-6 rounded-xl border bg-[var(--color-primary)]/5 hover:shadow-md transition">
          <p class="font-medium text-base">📖 Read</p>
          <p class="text-[var(--color-muted)] mt-2">
            Start with a short passage and reflection
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-[var(--color-primary)]/5 hover:shadow-md transition">
          <p class="font-medium text-base">✍️ Reflect</p>
          <p class="text-[var(--color-muted)] mt-2">
            Write honestly and process what you’re learning
          </p>
        </div>

        <div class="p-6 rounded-xl border bg-[var(--color-primary)]/5 hover:shadow-md transition">
          <p class="font-medium text-base">🔁 Apply</p>
          <p class="text-[var(--color-muted)] mt-2">
            Take one small step each day
          </p>
        </div>

      </div>

    </section>

    <!-- 🚀 PLANS -->
    <section class="space-y-8">

      <div class="flex justify-between items-center">
        <h2 class="text-2xl font-semibold">Start a Plan</h2>

        <a href="/plans" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-primary)]">
          View all →
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">

        {uniquePlans.map((plan) => (
          <a
            href={`/plans/${plan}`}
            class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 hover:bg-[var(--color-primary)]/10 hover:shadow-md hover:scale-[1.02] transition"
          >
            <h3 class="font-medium capitalize text-base">
              {plan.replace(/-/g, ' ')}
            </h3>

            <p class="text-sm text-[var(--color-muted)] mt-2 leading-relaxed">
              A guided journey to build consistency and grow daily.
            </p>

            <p class="mt-4 text-sm text-[var(--color-primary)] font-medium">
              Start →
            </p>
          </a>
        ))}

      </div>

    </section>

    <!-- 📖 DEVOTIONALS -->
    <section class="space-y-8">

      <div class="flex justify-between items-center">
        <h2 class="text-2xl font-semibold">Latest Devotionals</h2>

        <a href="/devotionals" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-primary)]">
          View all →
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">

        {devotionals.map((post) => (
          <a
            href={`/devotionals/${post.id}`}
            class="p-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-primary)]/5 hover:bg-[var(--color-primary)]/10 hover:shadow-md transition"
          >
            <h3 class="font-medium">{post.data.title}</h3>

            <p class="text-sm text-[var(--color-muted)] mt-2 line-clamp-2">
              {post.data.excerpt}
            </p>
          </a>
        ))}

      </div>

    </section>

  </div>

  <!-- 🧠 SCRIPT -->
  <script is:inline>
    const getSavedDays = (storageKey) => {
      try {
        const rawValue = localStorage.getItem(storageKey);
        const parsed = rawValue ? JSON.parse(rawValue) : [];
        return Array.isArray(parsed) ? parsed.filter((value) => Number.isInteger(value)) : [];
      } catch {
        return [];
      }
    };

    let latestPlan = null;
    let latestDay = 0;
    const totalDays = 7;

    Object.keys(localStorage).forEach((key) => {
      if (!key.startsWith('first7-')) return;

      const plan = key.replace('first7-', '');
      const days = getSavedDays(key);

      if (days.length === 0) return;

      const maxDay = Math.max(...days);

      if (maxDay > latestDay) {
        latestDay = maxDay;
        latestPlan = plan;
      }
    });

    const resumeBox = document.getElementById('resume-box');
    const resumeLink = document.getElementById('resume-link');

    if (latestPlan && resumeBox && resumeLink) {
      resumeBox.classList.remove('hidden');

      if (latestDay >= totalDays) {
        resumeLink.href = `/plans/${latestPlan}`;
        resumeLink.textContent = `View your journey →`;
      } else {
        resumeLink.href = `/plans/${latestPlan}/day-${latestDay + 1}`;
        resumeLink.textContent = `Resume Day ${latestDay + 1} →`;
      }
    }
  </script>

</BaseLayout>