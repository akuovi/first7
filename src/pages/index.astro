---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getStartPlanSummaries } from '../lib/start-plans';

// Get plans
const planSummaries = await getStartPlanSummaries();
const plans = planSummaries.map((summary) => summary.plan);

// Get blog posts
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

    <style>
  .hero {
    content-visibility: auto;
    contain-intrinsic-size: 500px;
  }
</style>

<BaseLayout title="First7">

  <!-- 🚀 HERO (CRITICAL OPTIMIZED) -->
  <section class="max-w-2xl mx-auto text-center py-20 px-5">

  <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold leading-tight">
    Walk with God, one day at a time
  </h1>

  <p class="mt-4 text-base sm:text-lg text-[var(--color-muted)]">
    You don’t need to have everything figured out.
    Just show up as you are.
  </p>

  <p class="text-sm sm:text-base text-[var(--color-muted)]">
    Read, reflect, and take one step forward — with God.
  </p>

    <div style="margin-top: 20px; display: flex; justify-content: center; gap: 16px;">
      <a
        href="/start"
        style="padding:12px 24px; border-radius:12px; background:var(--color-primary); color:white; text-decoration:none;"
      >
        Begin your journey →
      </a>

      <a
        href="/reflections"
        style="padding:12px 24px; border-radius:12px; border:1px solid var(--color-border); text-decoration:none;"
      >
        Explore reflections
      </a>
    </div>

  </section>

  <!-- HOW IT WORKS -->
  <section class="max-w-5xl mx-auto px-4 py-20">

    <div class="grid md:grid-cols-3 gap-8">

      <div class="p-6 rounded-2xl border border-[var(--color-border)] text-center space-y-4">
        <p class="text-2xl">📖</p>
        <p class="font-medium">Read</p>
        <p class="text-sm text-[var(--color-muted)]">
          Spend a few quiet minutes in Scripture
        </p>
      </div>

      <div class="p-6 rounded-2xl border border-[var(--color-border)] text-center space-y-4">
        <p class="text-2xl">✍️</p>
        <p class="font-medium">Reflect</p>
        <p class="text-sm text-[var(--color-muted)]">
          Notice what stands out
        </p>
      </div>

      <div class="p-6 rounded-2xl border border-[var(--color-border)] text-center space-y-4">
        <p class="text-2xl">🔁</p>
        <p class="font-medium">Take a step</p>
        <p class="text-sm text-[var(--color-muted)]">
          Take one simple step forward
        </p>
      </div>

    </div>

  </section>

  <!-- PLANS -->
  <section class="max-w-5xl mx-auto px-4 py-16 space-y-8">

    <h2 class="text-2xl font-semibold text-center">
      Start where you need it
    </h2>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">

      {plans.map((plan) => (
        <a
          href={`/plans/${plan}`}
          class="block rounded-2xl border border-[var(--color-border)] p-6"
        >
          <h3 class="font-semibold capitalize">
            {plan.replace(/-/g, " ")}
          </h3>

          <p class="mt-2 text-sm text-[var(--color-muted)]">
            A quiet 7-day space
          </p>
        </a>
      ))}

    </div>

  </section>

  <!-- BLOG -->
  <section class="max-w-5xl mx-auto px-4 py-16 space-y-8">

    <div class="flex justify-between items-center">
      <h2 class="text-2xl font-semibold">
        From the journey
      </h2>

      <a href="/blog" class="text-sm text-[var(--color-primary)]">
        View all →
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-3">

      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="block rounded-2xl border border-[var(--color-border)] p-5"
        >
          <h3 class="font-medium">
            {post.data.title}
          </h3>

          <p class="mt-2 text-sm text-[var(--color-muted)] line-clamp-3">
            {post.data.excerpt}
          </p>

          <div class="mt-3 text-xs text-[var(--color-muted)]">
            {post.data.date.toLocaleDateString()}
          </div>
        </a>
      ))}

    </div>

  </section>

</BaseLayout>