---
import { getCollection, render } from 'astro:content';
import ReflectionBox from '../../components/ReflectionBox.astro';
import ReadingLayout from '../../layouts/ReadingLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('devotionals');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<ReadingLayout title={post.data.title}>
  <div class="mx-auto max-w-2xl space-y-8 px-4 py-10">
    <p class="text-sm text-[var(--color-muted)]">Day {post.data.day}</p>

    <h1 class="text-3xl font-semibold leading-tight md:text-4xl">
      {post.data.title}
    </h1>

    <p class="text-[var(--color-muted)]">{post.data.excerpt}</p>

    <div class="space-y-6 text-lg leading-relaxed">
      <Content />
    </div>

    <ReflectionBox id={post.id} />

    <div class="mt-10 rounded-xl border p-4">
      <p class="text-sm text-[var(--color-muted)]">Streak</p>
      <p id="streak-count" class="text-2xl font-semibold">0 days</p>
    </div>

    <div class="mt-10 space-y-4">
      <p class="text-sm text-[var(--color-muted)]">Recent Reflections</p>
      <div id="reflection-history" class="space-y-3"></div>
    </div>
  </div>

  <script is:inline define:vars={{ id: post.id }}>
    const reflectionKey = `reflection-${id}`;
    const historyKey = 'reflection-history';
    const streakKey = 'reflection-streak';

    const textarea = document.getElementById(`reflection-${id}`);
    const status = document.getElementById(`save-status-${id}`);

    if (textarea instanceof HTMLTextAreaElement) {
      const saved = localStorage.getItem(reflectionKey);

      if (saved) {
        textarea.value = saved;
        if (status) {
          status.textContent = 'Saved';
        }
      }

      textarea.addEventListener('input', () => {
        localStorage.setItem(reflectionKey, textarea.value);
        if (status) {
          status.textContent = 'Saved';
        }
      });
    }

    const saveReflectionMeta = () => {
      const today = new Date().toISOString().split('T')[0];

      let history = [];
      try {
        history = JSON.parse(localStorage.getItem(historyKey) ?? '[]');
      } catch {}

      const exists = history.find((item) => item.id === id && item.date === today);
      if (!exists) {
        history.push({
          id,
          date: today,
          text: textarea instanceof HTMLTextAreaElement ? textarea.value : ''
        });
        localStorage.setItem(historyKey, JSON.stringify(history));
      }

      let streakData = {};
      try {
        streakData = JSON.parse(localStorage.getItem(streakKey) ?? '{}');
      } catch {}

      const lastDate = streakData.lastDate;
      let streak = streakData.count || 0;

      const yesterday = new Date();
      yesterday.setDate(yesterday.getDate() - 1);
      const yesterdayStr = yesterday.toISOString().split('T')[0];

      if (lastDate === today) {
      } else if (lastDate === yesterdayStr) {
        streak += 1;
      } else {
        streak = 1;
      }

      localStorage.setItem(
        streakKey,
        JSON.stringify({
          count: streak,
          lastDate: today
        })
      );
    };

    let hasSavedMeta = false;

    textarea?.addEventListener('input', () => {
      if (!hasSavedMeta) {
        saveReflectionMeta();
        hasSavedMeta = true;
      }
    });

    const streakEl = document.getElementById('streak-count');

    try {
      const streakData = JSON.parse(localStorage.getItem(streakKey) ?? '{}');
      if (streakEl) {
        const count = streakData.count || 0;
        streakEl.textContent = `${count} day${count === 1 ? '' : 's'}`;
      }
    } catch {}

    const historyEl = document.getElementById('reflection-history');

    try {
      const history = JSON.parse(localStorage.getItem(historyKey) ?? '[]');

      if (historyEl && history.length > 0) {
        const lastEntries = history.slice(-3).reverse();

        historyEl.innerHTML = lastEntries
          .map(
            (item) => `
              <div class="rounded-lg border border-[var(--color-border)] p-3">
                <p class="text-xs text-[var(--color-muted)]">${item.date}</p>
                <p class="mt-1 text-sm">${item.text || 'No content'}</p>
              </div>
            `
          )
          .join('');
      }
    } catch {}
  </script>
</ReadingLayout>
