---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('devotionals')).sort((a, b) => a.data.day - b.data.day);
const featured = posts[posts.length - 1];
---

<BaseLayout>
  <div class="mx-auto max-w-4xl space-y-10 px-4 py-10">
    <h1 class="text-3xl font-semibold">Devotionals</h1>

    {featured && (
      <a
        href={`/devotionals/${featured.id}`}
        class="block rounded-3xl border border-[var(--color-border)] bg-gradient-to-br from-[var(--color-primary)]/5 to-transparent p-6 transition hover:bg-[var(--color-primary)]/5 md:p-8"
      >
        <p class="text-sm text-[var(--color-muted)]">Featured Devotional</p>

        <h2 class="mt-2 text-2xl font-semibold leading-tight md:text-3xl">
          {featured.data.title}
        </h2>

        <p class="mt-3 max-w-xl text-[var(--color-muted)]">
          {featured.data.excerpt}
        </p>

        <div class="mt-4 flex items-center justify-between">
          <span class="text-sm text-[var(--color-muted)]">Day {featured.data.day}</span>

          <span class="font-medium text-[var(--color-primary)]">Read -&gt;</span>
        </div>
      </a>
    )}

    <div class="grid gap-6 md:grid-cols-2">
      {posts
        .filter((post) => post.id !== featured?.id)
        .map((post) => (
          <a
            href={`/devotionals/${post.id}`}
            class="group rounded-2xl border border-[var(--color-border)] p-5 transition hover:bg-[var(--color-primary)]/5 hover:shadow-sm"
          >
            <div class="flex items-center justify-between">
              <p class="text-sm text-[var(--color-muted)]">Day {post.data.day}</p>

              <span class="text-[var(--color-muted)] transition group-hover:translate-x-1">
                -&gt;
              </span>
            </div>

            <h2 class="mt-2 text-lg font-semibold leading-snug">{post.data.title}</h2>

            <p class="mt-2 line-clamp-2 text-sm text-[var(--color-muted)]">
              {post.data.excerpt}
            </p>
          </a>
        ))}
    </div>
  </div>
</BaseLayout>
